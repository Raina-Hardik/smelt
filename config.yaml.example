# smelt configuration
# Generated by `smelt config init`. Copy to config.yaml or pass --config <path>.
# All values can be overridden with CLI flags or SMELT_* environment variables.
# Precedence: CLI flag > env var > config.yaml > built-in default.

smelt:
  # Maximum simultaneous ffmpeg processes. 0 = runtime.NumCPU().
  workers: 0

  # Log verbosity: debug | info | warn | error
  log_level: info

  # Log format: auto | json | pretty
  # auto selects pretty when stdout is a TTY, json otherwise.
  log_format: auto

transcode:
  # Root directory to scan recursively for media files.
  src: ""

  # File extensions to match (case-insensitive, leading dot optional).
  ext:
    - mkv
    - mp4
    - avi

  # Target video codec: h264 | h265 | av1 | vp9
  codec: h265

  # Constant rate factor, 0-51. Lower = higher quality, larger file.
  crf: 23

  # ffmpeg encoding preset: ultrafast | fast | medium | slow | veryslow
  # Normalized into the resolved encoder's namespace (e.g. nvenc, svt-av1).
  preset: medium

  # Hardware acceleration: auto | none | nvenc | qsv | vaapi | amf | videotoolbox
  # "auto" probes for a usable GPU encoder and falls back to software.
  hwaccel: auto

  # Hardware decode: auto | off. "auto" decodes on the hardware encoder's own
  # device when a per-file probe confirms the source is decodable there, else
  # software (a hardware-decode failure retries that file once in software).
  # "off" forces software decode. No effect with a software encoder.
  hwdecode: auto

  # Audio codec: copy | aac | opus | mp3 | ac3 | flac
  # "copy" stream-copies the audio untouched; others re-encode.
  audio_codec: copy

  # Audio bitrate when re-encoding (e.g. 192k). Ignored when audio_codec: copy.
  audio_bitrate: ""

  # Replace original file after a confirmed successful transcode.
  # WARNING: the original is unrecoverable after this operation.
  # Files already in the target codec are skipped (override with force: true).
  inplace: false

  # With inplace, skip files hardlinked elsewhere (transcoding would break the
  # link and double disk usage). Useful for ARR/seedbox setups.
  skip_hardlinked: false

  # Re-transcode even when a file is already up to date (disables all skipping).
  force: false

  # Target container/format: mp4 | mkv | webm | ... Empty keeps the source
  # container. Changes the muxer only, not the codec. Exclusive with inplace.
  to: ""

  # Write output files to this directory instead of alongside the source.
  # The directory must exist. Mutually exclusive with inplace: true.
  output_dir: ""

  # Output filename suffix for files written alongside the source
  # (<name><suffix><ext>). Ignored for inplace and output_dir.
  suffix: ".smelt"

# Named profiles — apply with: smelt transcode --profile <name>
# Profile values override codec, crf, and preset when active.
profiles:
  web:
    codec: h264
    crf: 28
    preset: fast
    extra_args:
      - "-movflags"
      - "+faststart"

  archive:
    codec: h265
    crf: 18
    preset: slow

  mobile:
    codec: h264
    crf: 30
    preset: fast
    extra_args:
      - "-vf"
      - "scale=1280:-2"
      - "-movflags"
      - "+faststart"
