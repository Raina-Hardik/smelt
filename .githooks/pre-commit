#!/usr/bin/env bash
# Pre-commit: auto-format staged Go files, then vet and lint.
set -euo pipefail

staged=$(git diff --cached --name-only --diff-filter=ACM | grep '\.go$' || true)

if [ -n "$staged" ]; then
  # shellcheck disable=SC2086
  gofmt -w $staged
  # shellcheck disable=SC2086
  git add $staged
fi

go vet ./...

if command -v golangci-lint &>/dev/null; then
  golangci-lint run ./...
else
  echo "warning: golangci-lint not found; skipping lint (run: go install github.com/golangci/golangci-lint/v2/cmd/golangci-lint@v2.12.2)"
fi
